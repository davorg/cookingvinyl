#!/usr/bin/perl

use strict;
use warnings;
use feature 'say';

use JSON;
use Cooking::Schema;

@ARGV or die "Gimme a JSON file\n";

my $sch = Cooking::Schema->get_schema;
my $rs  = $sch->resultset('Artist');

my $json = do { local $/; <> };

my $artists = JSON->new->decode($json);

for (@$artists) {
  next unless defined $_->{blurb};
  my $artist = $rs->find({ name => $_->{name} });

  unless ($artist) {
    warn "Can't find $_->{name}\n";
    next;
  }

  $artist->update({ blurb => $_->{blurb} });
}
